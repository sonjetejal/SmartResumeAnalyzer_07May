                    @foreach (var edu in analysis.Education)
                    {
                        <li class="mb-1"><i class="bi bi-check-circle text-success me-2"></i>@edu</li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (analysis.WorkExperiences.Count > 0)
    {
        <div class="col-md-6">
            <div class="card p-4 h-100">
                <h5><i class="bi bi-briefcase me-2 text-warning"></i>Work Experience</h5>
                <ul class="list-unstyled mt-2 mb-0">
                    @foreach (var exp in analysis.WorkExperiences)
                    {
                        <li class="mb-1"><i class="bi bi-building me-2 text-muted"></i>@exp.JobTitle</li>
                    }
                </ul>
