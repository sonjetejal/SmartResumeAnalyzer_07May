@model SmartResumeAnalyzer.Models.Resume
@{
    ViewData["Title"] = "ATS Score";
    double score = ViewBag.Score;
    var scoreClass = score >= 80 ? "score-high" : score >= 60 ? "score-mid" : "score-low";
    var message = score >= 80 ? "Excellent ATS compatibility!"
                : score >= 60 ? "Your resume is reasonably ATS-friendly."
                : "Your resume may not pass ATS screening. Review formatting and content.";
    var alertClass = score >= 80 ? "alert-success" : score >= 60 ? "alert-warning" : "alert-danger";
    var icon = score >= 80 ? "bi-shield-fill-check text-success" : score >= 60 ? "bi-shield-fill-exclamation text-warning" : "bi-shield-fill-x text-danger";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2><i class="bi bi-shield-check me-2 text-primary"></i>ATS Compatibility Score</h2>
    <a asp-action="Results" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Results
    </a>
</div>

<div class="row justify-content-center mb-4">
    <div class="col-md-5 text-center">
        <div class="card p-5">
            <p class="text-muted small fw-semibold text-uppercase mb-3">ATS Score for</p>
            <p class="fw-semibold text-truncate">@Model.FileName</p>
            <div class="score-circle @scoreClass mx-auto my-3">@score.ToString("F0")<span class="fs-6">%</span></div>
            <div class="alert @alertClass mt-3 mb-0 text-start">
                <i class="bi @icon me-2"></i>@message
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card p-4 h-100">
            <h5 class="mb-3">What ATS Checks</h5>
            @{
                var checks = new[]
                {
                    ("Education section present", Model.Content.Contains("education", StringComparison.OrdinalIgnoreCase)),
                    ("Experience section present", Model.Content.Contains("experience", StringComparison.OrdinalIgnoreCase)),
                    ("Skills section present", Model.Content.Contains("skills", StringComparison.OrdinalIgnoreCase)),
                    ("Contact info present", Model.Content.Contains("contact", StringComparison.OrdinalIgnoreCase)),
                    ("Sufficient content length", Model.Content.Length >= 300),
                };
            }
            <ul class="list-unstyled mb-0">
                @foreach (var (label, passed) in checks)
                {
                    <li class="d-flex align-items-center mb-2">
                        <i class="bi @(passed ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") me-3 fs-5"></i>
                        <span>@label</span>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
