@model List<SmartResumeAnalyzer.Models.Resume>
@{
    ViewData["Title"] = "Search Resumes";
    var query = ViewBag.Query as string;
}

<h2 class="mb-4"><i class="bi bi-search me-2 text-primary"></i>Search Resumes</h2>

<div class="card p-4 mb-4">
    <form method="post" asp-controller="Resume" asp-action="Search">
        <div class="input-group">
            <input type="text" name="query" class="form-control form-control-lg"
                   placeholder="Search by skill, filename, or keyword..." value="@query" />
            <button class="btn btn-primary btn-lg" type="submit">
                <i class="bi bi-search me-1"></i>Search
            </button>
        </div>
    </form>
</div>

@if (Model != null)
{
    if (Model.Count == 0)
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No resumes found matching "@query".</div>
    }
    else
    {
        <p class="text-muted mb-3">Found <strong>@Model.Count</strong> result(s) for "@query"</p>
        <div class="row g-3">
            @foreach (var resume in Model)
            {
                <div class="col-md-6">
                    <div class="card p-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-semibold mb-1"><i class="bi bi-file-earmark-text me-2 text-primary"></i>@resume.FileName</h6>
                                <small class="text-muted">ID: @resume.Id.Substring(0, 8)...</small><br />
                                <small class="text-muted">Uploaded: @resume.UploadedDate.ToString("MMM dd, yyyy")</small>
                            </div>
                            @if (resume.Analysis != null)
                            {
                                var sc = resume.Analysis.OverallScore;
                                var badge = sc >= 75 ? "bg-success" : sc >= 50 ? "bg-warning text-dark" : "bg-danger";
                                <span class="badge @badge fs-6">@sc.ToString("F0")</span>
                            }
                        </div>
                        <div class="mt-2">
                            <a asp-action="Results" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-bar-chart-line me-1"></i>Results
                            </a>
                            <a asp-action="ATSScore" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-shield-check me-1"></i>ATS Score
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
