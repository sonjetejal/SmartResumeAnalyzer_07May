@model List<SmartResumeAnalyzer.Models.Resume>
@{
    ViewData["Title"] = "History";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2><i class="bi bi-clock-history me-2 text-primary"></i>Resume History</h2>
    <a asp-action="Analyze" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Analyze New
    </a>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="card p-5 text-center">
        <i class="bi bi-inbox display-4 text-muted mb-3"></i>
        <p class="text-muted mb-3">No resumes analyzed yet.</p>
        <a asp-action="Analyze" class="btn btn-primary">Analyze Your First Resume</a>
    </div>
}
else
{
    <div class="card">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>File</th>
                    <th>Uploaded</th>
                    <th class="text-center">Score</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var resume in Model.OrderByDescending(r => r.UploadedDate))
                {
                    <tr>
                        <td>
                            <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                            @resume.FileName
                            <br /><small class="text-muted">@resume.Id.Substring(0, 8)...</small>
                        </td>
                        <td><small>@resume.UploadedDate.ToString("MMM dd, yyyy HH:mm")</small></td>
                        <td class="text-center">
                            @if (resume.Analysis != null)
                            {
                                var sc = resume.Analysis.OverallScore;
                                var badge = sc >= 75 ? "bg-success" : sc >= 50 ? "bg-warning text-dark" : "bg-danger";
                                <span class="badge @badge">@sc.ToString("F0")</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (resume.Analysis != null)
                            {
                                <a asp-action="Results" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-primary me-1">Results</a>
                                <a asp-action="ATSScore" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-secondary me-1">ATS</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
