@{
    ViewData["Title"] = "Analyze Resume";
}

<h2 class="mb-4"><i class="bi bi-cloud-upload me-2 text-primary"></i>Analyze Resume</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<div class="card p-4">
    <form method="post" enctype="multipart/form-data" asp-controller="Resume" asp-action="Analyze">
        <div class="mb-4">
            <label class="form-label fw-semibold">Resume File <span class="text-danger">*</span></label>
            <input type="file" name="resumeFile" class="form-control" accept=".txt,.pdf,.docx" required />
            <div class="form-text">Supported formats: .txt, .pdf, .docx</div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Job Description <span class="text-muted">(optional)</span></label>
            <textarea name="jobDescription" class="form-control" rows="6"
                placeholder="Paste the job description here to get a match analysis..."></textarea>
            <div class="form-text">Leave blank to perform a general analysis.</div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg">
            <i class="bi bi-lightning-charge me-2"></i>Analyze Now
        </button>
    </form>
</div>
