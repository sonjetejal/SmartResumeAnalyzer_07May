@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <i class="bi bi-file-earmark-person display-1 text-primary"></i>
    <h1 class="mt-3 fw-bold">Smart Resume Analyzer</h1>
    <p class="lead text-muted">AI-powered resume analysis with ML.NET — extract skills, score your resume, and get job-match insights.</p>
    <a asp-controller="Resume" asp-action="Analyze" class="btn btn-primary btn-lg mt-3 me-2">
        <i class="bi bi-cloud-upload me-2"></i>Analyze Resume
    </a>
    <a asp-controller="Resume" asp-action="Search" class="btn btn-outline-secondary btn-lg mt-3">
        <i class="bi bi-search me-2"></i>Search Resumes
    </a>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <i class="bi bi-cpu display-5 text-primary mb-3"></i>
            <h5 class="fw-semibold">ML-Powered Skill Detection</h5>
            <p class="text-muted small">Automatically extracts technical and soft skills using ML.NET with confidence scoring.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <i class="bi bi-bar-chart display-5 text-success mb-3"></i>
            <h5 class="fw-semibold">Comprehensive Scoring</h5>
            <p class="text-muted small">Overall score plus category-level scores for Skills, Experience, Education, and Certifications.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 text-center p-4">
            <i class="bi bi-briefcase display-5 text-warning mb-3"></i>
            <h5 class="fw-semibold">Job Match Analysis</h5>
            <p class="text-muted small">Compare your resume against a job description to see how well you match requirements.</p>
        </div>
    </div>
</div>
